# Server Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/disastersync

# Server Port
PORT=5000

# JWT Secret (change this to a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# NASA FIRMS API Key for Wildfire Monitoring
# Get your free API key at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_API_KEY=YOUR_NASA_FIRMS_API_KEY_HERE

# Wildfire Monitoring Area (Optional - defaults to India)
# Customize these coordinates for your region of interest
WILDFIRE_MIN_LAT=8.0
WILDFIRE_MAX_LAT=35.0
WILDFIRE_MIN_LON=68.0
WILDFIRE_MAX_LON=97.0

# Minimum confidence level for wildfire detection: low, nominal, high
WILDFIRE_MIN_CONFIDENCE=nominal
